# Copy this file to .env.local and fill in your values.

# ─── Anthropic (Claude AI) ──────────────────────────────────────────────────
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ─── Procore environment ────────────────────────────────────────────────────
# "sandbox"    → hits sandbox.procore.com (for dev/testing)
# "production" → hits api.procore.com (real Procore accounts, e.g. Fleek)
PROCORE_ENV=sandbox

# Optional URL overrides (leave blank unless you know you need them):
# PROCORE_API_BASE_URL=https://api.procore.com
# PROCORE_LOGIN_BASE_URL=https://login.procore.com

# ─── Procore OAuth ──────────────────────────────────────────────────────────
# Get these from: https://developers.procore.com → My Apps → ITP Reviewer → OAuth Credentials
# IMPORTANT: sandbox and production apps have DIFFERENT Client IDs / Secrets.
PROCORE_CLIENT_ID=your-procore-client-id-here
PROCORE_CLIENT_SECRET=your-procore-client-secret-here
PROCORE_REDIRECT_URI=http://localhost:3010/api/auth/callback

# ─── Access control ─────────────────────────────────────────────────────────
# Only Procore users who belong to this company are permitted to log in.
# Remove or leave blank to disable the company membership check (dev only).
FLEEK_COMPANY_ID=598134325535477
